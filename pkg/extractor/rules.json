{
  "_comment": "Default rule set for hush. Each entry: {name, type, pattern, value_group}. type is 'secret' or 'pii' (default 'secret'). value_group 0 means the whole match is the secret; value_group 1 means capture group 1 is the secret value (used when the regex frames the secret with surrounding keyword/quote tokens). Many patterns are adapted from the gitleaks canonical config (https://github.com/gitleaks/gitleaks, MIT license) with modifications to fit Go's RE2 engine (no lookahead/lookbehind/backrefs). Gitleaks rules that relied on RE2-incompatible features were rewritten where possible or skipped otherwise. Credit: github.com/gitleaks/gitleaks.",
  "rules": [
    {"name": "aws_access_key_id", "type": "secret", "pattern": "\\b(?:AKIA|ASIA|AIDA|AGPA|ANPA|AROA|AIPA|ANVA)[0-9A-Z]{16}\\b"},
    {"name": "aws_secret_access_key", "type": "secret", "pattern": "(?i)aws(?:.{0,20})?(?:secret|sk)[\\w\\s\\-=\"':]{0,20}([A-Za-z0-9/+=]{40})\\b", "value_group": 1},
    {"name": "aws_session_token", "type": "secret", "pattern": "(?i)aws_session_token\\s*[:=]\\s*['\"]?([A-Za-z0-9/+=]{100,})['\"]?", "value_group": 1},
    {"name": "gcp_service_account", "type": "secret", "pattern": "\"type\"\\s*:\\s*\"service_account\""},
    {"name": "gcp_oauth_client_secret", "type": "secret", "pattern": "\\bGOCSPX-[A-Za-z0-9_\\-]{28}\\b"},
    {"name": "gcp_api_key", "type": "secret", "pattern": "\\bAIza[0-9A-Za-z\\-_]{35}\\b"},
    {"name": "google_api_key", "type": "secret", "pattern": "\\bAIza[0-9A-Za-z\\-_]{35}\\b"},
    {"name": "azure_storage_connection_string", "type": "secret", "pattern": "DefaultEndpointsProtocol=https;AccountName=[a-z0-9]+;AccountKey=[A-Za-z0-9+/=]{60,}"},
    {"name": "azure_storage_account_key", "type": "secret", "pattern": "(?i)AccountKey\\s*=\\s*([A-Za-z0-9+/=]{80,})", "value_group": 1},
    {"name": "azure_sas_token", "type": "secret", "pattern": "(?i)\\bsig=[A-Za-z0-9%_\\-]{40,}&se=[0-9TZ:\\-]+"},
    {"name": "digitalocean_pat", "type": "secret", "pattern": "\\bdop_v1_[a-f0-9]{64}\\b"},
    {"name": "digitalocean_oauth_token", "type": "secret", "pattern": "\\bdoo_v1_[a-f0-9]{64}\\b"},
    {"name": "linode_pat", "type": "secret", "pattern": "(?i)linode[_\\-\\s]?(?:api|token|pat)[_\\-\\s]?[:=]\\s*['\"]?([a-f0-9]{64})['\"]?", "value_group": 1},
    {"name": "alibaba_access_key_id", "type": "secret", "pattern": "\\bLTAI[A-Za-z0-9]{12,20}\\b"},
    {"name": "openai_api_key", "type": "secret", "pattern": "\\bsk-(?:proj-)?[A-Za-z0-9_\\-]{20,}\\b"},
    {"name": "anthropic_api_key", "type": "secret", "pattern": "\\bsk-ant-[A-Za-z0-9_\\-]{20,}\\b"},
    {"name": "huggingface_token", "type": "secret", "pattern": "\\bhf_[A-Za-z0-9]{34,}\\b"},
    {"name": "cohere_api_key", "type": "secret", "pattern": "(?i)cohere[_\\-]?api[_\\-]?key\\s*[:=]\\s*['\"]?([A-Za-z0-9]{40})['\"]?", "value_group": 1},
    {"name": "replicate_api_token", "type": "secret", "pattern": "\\br8_[A-Za-z0-9]{37,}\\b"},
    {"name": "github_pat", "type": "secret", "pattern": "\\bgh[pousr]_[A-Za-z0-9]{36,}\\b"},
    {"name": "github_fine_grained_pat", "type": "secret", "pattern": "\\bgithub_pat_[A-Za-z0-9_]{22,}\\b"},
    {"name": "gitlab_pat", "type": "secret", "pattern": "\\bglpat-[A-Za-z0-9_\\-]{20}\\b"},
    {"name": "gitlab_runner_token", "type": "secret", "pattern": "\\bglrt-[A-Za-z0-9_\\-]{20}\\b"},
    {"name": "bitbucket_app_password", "type": "secret", "pattern": "\\bATBB[A-Za-z0-9]{32,}\\b"},
    {"name": "stripe_secret", "type": "secret", "pattern": "\\b(?:sk|rk)_(?:test|live)_[A-Za-z0-9]{16,}\\b"},
    {"name": "stripe_publishable_key", "type": "secret", "pattern": "\\bpk_(?:test|live)_[A-Za-z0-9]{16,}\\b"},
    {"name": "slack_bot_token", "type": "secret", "pattern": "\\bxox[baprs]-[A-Za-z0-9\\-]{10,}\\b"},
    {"name": "slack_webhook_url", "type": "secret", "pattern": "https://hooks\\.slack\\.com/services/T[A-Z0-9]{8,}/B[A-Z0-9]{8,}/[A-Za-z0-9]{20,}"},
    {"name": "discord_bot_token", "type": "secret", "pattern": "\\b[MNO][A-Za-z0-9_\\-]{23,26}\\.[A-Za-z0-9_\\-]{6,7}\\.[A-Za-z0-9_\\-]{27,}\\b"},
    {"name": "discord_webhook_url", "type": "secret", "pattern": "https://(?:discord|discordapp)\\.com/api/webhooks/[0-9]{17,20}/[A-Za-z0-9_\\-]{60,}"},
    {"name": "telegram_bot_token", "type": "secret", "pattern": "\\b[0-9]{8,10}:[A-Za-z0-9_\\-]{35}\\b"},
    {"name": "teams_webhook_url", "type": "secret", "pattern": "https://[a-z0-9\\-]+\\.webhook\\.office\\.com/webhookb2/[A-Za-z0-9_\\-@]+/IncomingWebhook/[A-Za-z0-9]+/[A-Za-z0-9\\-]+"},
    {"name": "twilio_api_key", "type": "secret", "pattern": "\\bSK[a-f0-9]{32}\\b"},
    {"name": "twilio_account_sid", "type": "secret", "pattern": "\\bAC[a-f0-9]{32}\\b"},
    {"name": "sendgrid_api_key", "type": "secret", "pattern": "\\bSG\\.[A-Za-z0-9_\\-]{22}\\.[A-Za-z0-9_\\-]{43}\\b"},
    {"name": "mailgun_api_key", "type": "secret", "pattern": "\\bkey-[a-f0-9]{32}\\b"},
    {"name": "mailchimp_api_key", "type": "secret", "pattern": "\\b[a-f0-9]{32}-us[0-9]{1,2}\\b"},
    {"name": "pagerduty_api_key", "type": "secret", "pattern": "(?i)pagerduty[_\\-]?(?:api|token)[_\\-]?key\\s*[:=]\\s*['\"]?([A-Za-z0-9+_\\-]{20,32})['\"]?", "value_group": 1},
    {"name": "datadog_api_key", "type": "secret", "pattern": "(?i)(?:datadog|dd)[_\\-]?api[_\\-]?key\\s*[:=]\\s*['\"]?([a-f0-9]{32})['\"]?", "value_group": 1},
    {"name": "newrelic_license_key", "type": "secret", "pattern": "\\b[A-Fa-f0-9]{40}NRAL\\b"},
    {"name": "newrelic_user_api_key", "type": "secret", "pattern": "\\bNRAK-[A-Z0-9]{27}\\b"},
    {"name": "cloudflare_api_token", "type": "secret", "pattern": "(?i)cloudflare[_\\-]?(?:api[_\\-]?)?token\\s*[:=]\\s*['\"]?([A-Za-z0-9_\\-]{40})['\"]?", "value_group": 1},
    {"name": "cloudflare_global_api_key", "type": "secret", "pattern": "(?i)cloudflare[_\\-]?(?:global[_\\-]?)?api[_\\-]?key\\s*[:=]\\s*['\"]?([a-f0-9]{37})['\"]?", "value_group": 1},
    {"name": "shopify_access_token", "type": "secret", "pattern": "\\bshpat_[a-fA-F0-9]{32}\\b"},
    {"name": "shopify_shared_secret", "type": "secret", "pattern": "\\bshpss_[a-fA-F0-9]{32}\\b"},
    {"name": "shopify_private_app_token", "type": "secret", "pattern": "\\bshppa_[a-fA-F0-9]{32}\\b"},
    {"name": "shopify_custom_app_token", "type": "secret", "pattern": "\\bshpca_[a-fA-F0-9]{32}\\b"},
    {"name": "square_access_token", "type": "secret", "pattern": "\\b(?:EAAA|sq0atp-)[A-Za-z0-9_\\-]{22,60}\\b"},
    {"name": "square_oauth_secret", "type": "secret", "pattern": "\\bsq0csp-[A-Za-z0-9_\\-]{43}\\b"},
    {"name": "paypal_access_token", "type": "secret", "pattern": "\\baccess_token\\$production\\$[a-z0-9]{16}\\$[a-f0-9]{32}\\b"},
    {"name": "atlassian_api_token", "type": "secret", "pattern": "(?i)atlassian[_\\-]?(?:api[_\\-]?)?token\\s*[:=]\\s*['\"]?([A-Za-z0-9]{24})['\"]?", "value_group": 1},
    {"name": "okta_api_token", "type": "secret", "pattern": "(?i)okta[_\\-]?(?:api[_\\-]?)?token\\s*[:=]\\s*['\"]?(00[A-Za-z0-9_\\-]{38,42})['\"]?", "value_group": 1},
    {"name": "auth0_api_token", "type": "secret", "pattern": "(?i)auth0[_\\-]?(?:api[_\\-]?)?token\\s*[:=]\\s*['\"]?([A-Za-z0-9_\\-]{32,})['\"]?", "value_group": 1},
    {"name": "heroku_api_key", "type": "secret", "pattern": "(?i)heroku[_\\-]?(?:api[_\\-]?)?key\\s*[:=]\\s*['\"]?([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})['\"]?", "value_group": 1},
    {"name": "npm_token", "type": "secret", "pattern": "\\bnpm_[A-Za-z0-9]{36}\\b"},
    {"name": "pypi_token", "type": "secret", "pattern": "\\bpypi-AgE[A-Za-z0-9_\\-]{50,}\\b"},
    {"name": "dockerhub_pat", "type": "secret", "pattern": "\\bdckr_pat_[A-Za-z0-9_\\-]{27,}\\b"},
    {"name": "crates_io_token", "type": "secret", "pattern": "\\bcio[A-Za-z0-9]{32,}\\b"},
    {"name": "terraform_cloud_token", "type": "secret", "pattern": "\\b[A-Za-z0-9]{14}\\.atlasv1\\.[A-Za-z0-9_\\-]{60,}\\b"},
    {"name": "circleci_token", "type": "secret", "pattern": "(?i)circle[_\\-]?ci[_\\-]?(?:api[_\\-]?)?token\\s*[:=]\\s*['\"]?([a-f0-9]{40})['\"]?", "value_group": 1},
    {"name": "jwt", "type": "secret", "pattern": "\\beyJ[A-Za-z0-9_\\-]{8,}\\.[A-Za-z0-9_\\-]{8,}\\.[A-Za-z0-9_\\-]{8,}\\b"},
    {"name": "private_key_pem", "type": "secret", "pattern": "(?s)-----BEGIN (?:RSA |DSA |EC |OPENSSH |PGP |ENCRYPTED )?PRIVATE KEY(?: BLOCK)?-----.*?-----END (?:RSA |DSA |EC |OPENSSH |PGP |ENCRYPTED )?PRIVATE KEY(?: BLOCK)?-----"},
    {"name": "x509_certificate", "type": "secret", "pattern": "(?s)-----BEGIN CERTIFICATE-----.*?-----END CERTIFICATE-----"},
    {"name": "pgp_private_key", "type": "secret", "pattern": "(?s)-----BEGIN PGP PRIVATE KEY BLOCK-----.*?-----END PGP PRIVATE KEY BLOCK-----"},
    {"name": "putty_private_key", "type": "secret", "pattern": "PuTTY-User-Key-File-[0-9]+: ssh-"},
    {"name": "db_uri_creds", "type": "secret", "pattern": "\\b(?:mongodb(?:\\+srv)?|postgres(?:ql)?|mysql|redis|amqp|rabbitmq|kafka)://[^\\s:@/]+:[^\\s:@/]+@[^\\s/]+"},
    {"name": "http_basic_auth_url", "type": "secret", "pattern": "\\bhttps?://[^\\s:@/]+:[^\\s:@/]+@[A-Za-z0-9\\.\\-]+"},
    {"name": "generic_assignment_secret", "type": "secret", "pattern": "(?i)(?:password|passwd|secret|token|api[_-]?key|auth)\\s*[:=]\\s*['\"]?([^\\s'\",;{}()]{8,})", "value_group": 1},

    {"name": "email_address", "type": "pii", "pattern": "\\b[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}\\b"},
    {"name": "ipv4_address", "type": "pii", "pattern": "\\b(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(?:\\.(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)){3}\\b"},
    {"name": "ipv6_address", "type": "pii", "pattern": "(?i)\\b(?:[0-9a-f]{1,4}:){7}[0-9a-f]{1,4}\\b"},
    {"name": "mac_address", "type": "pii", "pattern": "(?i)\\b(?:[0-9a-f]{2}[:\\-]){5}[0-9a-f]{2}\\b"},
    {"name": "phone_e164", "type": "pii", "pattern": "\\+[1-9][0-9]{7,14}\\b"},
    {"name": "phone_us", "type": "pii", "pattern": "\\b(?:\\(?[0-9]{3}\\)?[\\s\\-\\.])[0-9]{3}[\\s\\-\\.][0-9]{4}\\b"},
    {"name": "ssn_us", "type": "pii", "pattern": "\\b[0-9]{3}-[0-9]{2}-[0-9]{4}\\b"},
    {"name": "sin_ca", "type": "pii", "pattern": "\\b[1-9][0-9]{2}-[0-9]{3}-[0-9]{3}\\b"},
    {"name": "nin_uk", "type": "pii", "pattern": "(?i)\\b[A-CEGHJ-PR-TW-Z][A-CEGHJ-NPR-TW-Z][0-9]{6}[A-D]\\b"},
    {"name": "aadhaar_in", "type": "pii", "pattern": "\\b[2-9][0-9]{3}\\s?[0-9]{4}\\s?[0-9]{4}\\b"},
    {"name": "pan_in", "type": "pii", "pattern": "\\b[A-Z]{5}[0-9]{4}[A-Z]\\b"},
    {"name": "cpf_br", "type": "pii", "pattern": "\\b[0-9]{3}\\.[0-9]{3}\\.[0-9]{3}-[0-9]{2}\\b"},
    {"name": "credit_card_visa", "type": "pii", "pattern": "\\b4[0-9]{3}(?:[ \\-]?[0-9]{4}){3}(?:[ \\-]?[0-9]{3})?\\b"},
    {"name": "credit_card_mastercard", "type": "pii", "pattern": "\\b(?:5[1-5][0-9]{2}|222[1-9]|22[3-9][0-9]|2[3-6][0-9]{2}|27[01][0-9]|2720)(?:[ \\-]?[0-9]{4}){3}\\b"},
    {"name": "credit_card_amex", "type": "pii", "pattern": "\\b3[47][0-9]{2}[ \\-]?[0-9]{6}[ \\-]?[0-9]{5}\\b"},
    {"name": "credit_card_discover", "type": "pii", "pattern": "\\b6(?:011|5[0-9]{2})(?:[ \\-]?[0-9]{4}){3}\\b"},
    {"name": "credit_card_jcb", "type": "pii", "pattern": "\\b35(?:2[89]|[3-8][0-9])(?:[ \\-]?[0-9]{4}){3}\\b"},
    {"name": "iban", "type": "pii", "pattern": "\\b[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}\\b"},
    {"name": "ein_us", "type": "pii", "pattern": "\\b[0-9]{2}-[0-9]{7}\\b"},
    {"name": "itin_us", "type": "pii", "pattern": "\\b9[0-9]{2}-[7-9][0-9]-[0-9]{4}\\b"},
    {"name": "passport_us", "type": "pii", "pattern": "(?i)passport[^A-Za-z0-9]{0,10}([0-9]{9})\\b", "value_group": 1},
    {"name": "passport_uk", "type": "pii", "pattern": "(?i)passport[^A-Za-z0-9]{0,10}([0-9]{9})\\b", "value_group": 1},
    {"name": "passport_in", "type": "pii", "pattern": "\\b[A-PR-WYa-pr-wy][0-9]{7}\\b"},
    {"name": "drivers_license_us", "type": "pii", "pattern": "(?i)(?:driver'?s?[\\s_\\-]?licen[cs]e|DL|dln)[^A-Za-z0-9]{0,10}([A-Z0-9]{6,14})\\b", "value_group": 1}
  ]
}
